/Data RawData /FlateDecode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Decode [0 1 0 1 0 1]
  /DataSource Data
  /Height 800
  /ImageMatrix [2260 0 0 800 0 0]
  /Width 2260
  /BitsPerComponent 8
>> image
} stopped {handleerror} if
  RawData flushfile
} exec
