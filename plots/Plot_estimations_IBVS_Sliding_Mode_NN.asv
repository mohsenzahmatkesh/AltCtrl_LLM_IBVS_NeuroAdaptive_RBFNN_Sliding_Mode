close all
figure;
set(gcf, 'Position', [100, 100, 1000, 800]); % Adjust figure size
t = tiledlayout(4, 1, 'TileSpacing', 'compact', 'Padding', 'compact'); % Four plots stacked vertically

% ==========================================================
% --- First Plot ---
nexttile;
hold on;

load('Using_NN.mat');
% Red highlight + main lines
plot(tout, delta_h_phi, '-', 'LineWidth', 15, 'Color', [0.7 0.4 0.4 0.15], 'HandleVisibility', 'off');
h1 = plot(tout, delta_h_phi, '-', 'Color', [1 0 0], 'LineWidth', 2.5, 'DisplayName', '$\hat{\Delta}_\phi$');

% Black dashed line
h2 = plot(tout, delta_phi, 'k--', 'LineWidth', 2.5, 'DisplayName', '${\Delta}_\phi$');

ylabel('$\mathrm{\phi-\hat{\phi}~(deg)}$', 'Interpreter', 'latex', 'FontSize', 22);
grid on;
hold off;
set(gca, 'TickLabelInterpreter', 'latex', 'FontSize', 22);

% ==========================================================
% --- Second Plot ---
nexttile;
hold on;

% Red highlight + main lines
plot(tout, delta_h_theta, '-', 'LineWidth', 15, 'Color', [0.7 0.4 0.4 0.15], 'HandleVisibility', 'off');
plot(tout, delta_h_theta, '-', 'Color', [1 0 0], 'LineWidth', 2.5, 'DisplayName', '$\hat{\Delta}_\theta$');

% Black dashed line
plot(tout, delta_theta, 'k--', 'LineWidth', 2.5, 'DisplayName', '${\Delta}_\theta$');

ylabel('$\mathrm{\theta-\hat{\theta}~(deg)}$', 'Interpreter', 'latex', 'FontSize', 22);
grid on;
hold off;
set(gca, 'TickLabelInterpreter', 'latex', 'FontSize', 22);

% ==========================================================
% --- Third Plot ---
nexttile;
hold on;

% Red highlight + main lines
plot(tout, delta_h_psi, '-', 'LineWidth', 15, 'Color', [0.7 0.4 0.4 0.15], 'HandleVisibility', 'off');
plot(tout, delta_h_psi, '-', 'Color', [1 0 0], 'LineWidth', 2.5, 'DisplayName', '$\hat{\Delta}_\psi$');

% Black dashed line
plot(tout, delta_psi, 'k--', 'LineWidth', 2.5, 'DisplayName', '${\Delta}_\psi$');

ylabel('$\mathrm{\psi-\hat{\psi}~(deg)}$', 'Interpreter', 'latex', 'FontSize', 22);
grid on;
hold off;
set(gca, 'TickLabelInterpreter', 'latex', 'FontSize', 22);

% ==========================================================
% --- Fourth Plot ---
nexttile;
hold on;

% Red highlight + main lines
plot(tout, delta_h_z, '-', 'LineWidth', 15, 'Color', [0.9 0.4 0.4 0.25], 'HandleVisibility', 'off');
plot(tout, delta_h_z, '-', 'Color', [1 0 0], 'LineWidth', 2.5, 'DisplayName', '$\hat{\Delta}_z$');

% Black dashed line
plot(tout, delta_z, 'k--', 'LineWidth', 2.5, 'DisplayName', '${\Delta}_z$');

xlabel('$\mathrm{Time~(s)}$', 'Interpreter', 'latex', 'FontSize', 22);
ylabel('$\mathrm{z-\hat{z}~(m)}$', 'Interpreter', 'latex', 'FontSize', 22);
grid on;
hold off;
set(gca, 'TickLabelInterpreter', 'latex', 'FontSize', 22);

% ==========================================================
% --- Shared Legend Below ---
lgd = legend([h2 h1], {'${\Delta}$', '$\hat{\Delta}$'}, ...
    'Orientation', 'horizontal', 'Interpreter', 'latex', ...
    'FontSize', 18, 'Box', 'off');
lgd.Layout.Tile = 'south';

% ==========================================================
% --- Title Setup ---
% t.Title.String = 'Comparison of Estimated and Actual Disturbances';
t.Title.FontSize = 16;
t.Title.Interpreter = 'latex';
