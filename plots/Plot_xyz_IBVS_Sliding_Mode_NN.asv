close all
figure;
set(gcf, 'Position', [100, 100, 1000, 800]); % Adjust figure size
t = tiledlayout(3, 1, 'TileSpacing', 'compact', 'Padding', 'compact'); % ← changed here

% ==========================================================
% --- First Plot ---
nexttile;
hold on;
load('No_NN.mat');
% Desired trajectory (No NN) - light red solid
% plot(tout, xdes, '-', 'LineWidth', 15, 'Color', [0.7 0.4 0.4 0.15], 'HandleVisibility', 'off');
% h1 = plot(tout, xdes, '-', 'LineWidth', 2.5, 'Color', [1 0.3 0.3], 'DisplayName', 'Desired Traj RBF-NN-IBVS');
% load('Using_NN.mat');
% % Desired trajectory (Using NN) - light blue solid
% h2 = plot(tout, xdes, '-', 'LineWidth', 2.5, 'Color', [0.2 0.6 1], 'DisplayName', 'Desired Traj IBVS');
load('No_NN.mat');
% Red highlight + main line
plot(tout, x, '-', 'LineWidth', 15, 'Color', [0.7 0.4 0.4 0.15], 'HandleVisibility', 'off');
h3 = plot(tout, x, '-', 'Color', [1 0 0], 'LineWidth', 2.5, 'DisplayName', 'RBF-NN-IBVS-SMC');
load('Using_NN.mat');
% Blue main line
% plot(tout, x, '-', 'LineWidth', 15, 'Color', [0.7 0.4 0.4 0.15], 'HandleVisibility', 'off');
h4 = plot(tout, x, '-', 'Color', [0 0.3 1], 'LineWidth', 4.5, 'DisplayName', 'IBVS-SMC');
ylabel('$\mathrm{X~(m)}$', 'Interpreter', 'latex', 'FontSize', 22);
% ylim([-0.01 0.01]);
grid on;
hold off;
set(gca, 'TickLabelInterpreter', 'latex', 'FontSize', 22);
% ==========================================================
% --- Second Plot ---
nexttile;
hold on;
load('No_NN.mat');
% Desired trajectory (No NN) - light red solid
% plot(tout, ydes, '-', 'LineWidth', 15, 'Color', [0.7 0.4 0.4 0.15], 'HandleVisibility', 'off');
% plot(tout, ydes, '-', 'LineWidth', 2.5, 'Color', [1 0.3 0.3], 'DisplayName', 'Desired (No RBFNN)');
% load('Using_NN.mat');
% % Desired trajectory (Using NN) - light blue solid
% plot(tout, ydes, '-', 'LineWidth', 2.5, 'Color', [0.2 0.6 1], 'DisplayName', 'Desired (RBFNN)');

load('No_NN.mat');
plot(tout, y, '-', 'LineWidth', 15, 'Color', [0.7 0.4 0.4 0.15], 'HandleVisibility', 'off');
plot(tout, y, '-', 'Color', [1 0 0], 'LineWidth', 2.5, 'DisplayName', 'Without RBFNN');
load('Using_NN.mat');
plot(tout, y, '-', 'Color', [0 0.3 1], 'LineWidth', 4.5, 'DisplayName', 'Using RBFNN');
ylabel('$\mathrm{Y~(m)}$', 'Interpreter', 'latex', 'FontSize', 22);
% ylim([-0.01 0.01]);
grid on;
hold off;
set(gca, 'TickLabelInterpreter', 'latex', 'FontSize', 22);
% ==========================================================
% --- Third Plot ---
nexttile;
hold on;
load('No_NN.mat');
% Desired trajectory (No NN) - light red solid
% plot(tout, zdes, '-', 'LineWidth', 15, 'Color', [0.7 0.4 0.4 0.15], 'HandleVisibility', 'off');
% plot(tout, zdes, '-', 'LineWidth', 2.5, 'Color', [1 0.3 0.3], 'DisplayName', 'Desired (No RBFNN)');
% load('Using_NN.mat');
% % Desired trajectory (Using NN) - light blue solid
% plot(tout, zdes, '-', 'LineWidth', 2.5, 'Color', [0.2 0.6 1], 'DisplayName', 'Desired (RBFNN)');

load('No_NN.mat');
plot(tout, z, '-', 'LineWidth', 15, 'Color', [0.7 0.4 0.4 0.15], 'HandleVisibility', 'off');
plot(tout, z, '-', 'Color', [1 0 0], 'LineWidth', 2.5, 'DisplayName', 'Without RBFNN');
load('Using_NN.mat');
plot(tout, z, '-', 'Color', [0 0.3 1], 'LineWidth', 4.5, 'DisplayName', 'Using RBFNN');
xlabel('$\mathrm{Time~(s)}$', 'Interpreter', 'latex', 'FontSize', 22);
ylabel('$\mathrm{Z~(m)}$', 'Interpreter', 'latex', 'FontSize', 22);
ylim([1.9 2.1]);
grid on;
hold off;
set(gca, 'TickLabelInterpreter', 'latex', 'FontSize', 22);

% ==========================================================
ax = findall(gcf, 'Type', 'Axes'); % find all subplots
% ==========================================================
% --- Shared Legend Below ---
lgd = legend(ax(end), [h4 h3], ...
    {'RBF-NN-IBVS-SMC','IBVS-SMC'}, ...
    'Orientation', 'horizontal', 'Interpreter', 'latex', ...
    'FontSize', 18, 'Box', 'off');
lgd.Layout.Tile = 'north';
% ==========================================================
% --- Title Setup ---
% t.Title.String = 'Comparison of Variables With and Without NN';
t.Title.FontSize = 16;
t.Title.Interpreter = 'latex';











